# ─── .env.example ─────────────────────────────────────────────────────────────
# Salin file ini menjadi `.env` dan isi nilainya.
# JANGAN pernah commit file `.env` ke Git!

# ── Django ─────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=ganti-dengan-secret-key-panjang-dan-acak-minimal-50-karakter
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Firebase (Auth + Firestore — bukan Storage) ────────────────────────────────
# Path ke file service account JSON yang didownload dari Firebase Console:
# Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=/secrets/firebase-service-account.json

# ── Cloudinary (File Storage: gambar & lampiran) ──────────────────────────────
# Daftar gratis di: https://cloudinary.com/users/register_free
# Kredensial ada di: Dashboard → API Keys
#
# Gratis: 25 GB storage · 25 GB bandwidth/bulan · CDN global · auto-WebP
CLOUDINARY_CLOUD_NAME=nama-cloud-kamu
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=ganti-dengan-api-secret-dari-dashboard
CLOUDINARY_SECURE=True

# ── CORS ───────────────────────────────────────────────────────────────────────
# URL origin frontend React (pisahkan dengan koma jika lebih dari satu)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Email (SMTP Gmail sebagai contoh) ─────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@ipmjabar.or.id
EMAIL_HOST_PASSWORD=app-password-gmail-bukan-password-biasa
DEFAULT_FROM_EMAIL=PW IPM Jawa Barat <noreply@ipmjabar.or.id>

# Email admin yang menerima notifikasi pengaduan baru
ADMIN_NOTIF_EMAIL=admin@ipmjabar.or.id
